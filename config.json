{
  "app_name": "SMC Market Analyzer",
  "version": "1.0.0",
  "developer_mode": true,

  "exchange_settings": {
    "primary_exchange": "Binance",
    "testnet_enabled": true,
    "fee_tier": "VIP_0"
  },

  "timeframes": {
    "macro_trend": "4h",
    "execution": "15m",
    "scalp": "1m"
  },

  "smc_parameters": {
    "order_block": {
      "lookback_period": 50,
      "volume_threshold_multiplier": 1.5
    },

  "fvg": {
      "min_gap_size_percentage": 0.05,
      "mitigation_tolerance": 0.01
    },

    "liquidity_sweeps": {
      "swing_high_lookback": 20,
      "swing_low_lookback": 20
    }
  },

  "watchlists": {
    "crypto_majors": ["BTC/USDT", "ETH/USDT"],
    "altcoins": ["SUI/USDT", "XMR/USDT"]
  },
